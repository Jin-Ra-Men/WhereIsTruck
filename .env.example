# Map API (Google Maps 또는 Kakao Map)
MAP_API_KEY=
# MAP_PROVIDER=google|kakao

# Kakao Map (platform-specific keys)
# Web (JavaScript key)
KAKAO_JS_API_KEY=
# Backend REST key (server-side use if needed)
KAKAO_REST_API_KEY=
# Android/iOS (native app key)
KAKAO_NATIVE_APP_KEY=

# Database (PostgreSQL + PostGIS). 비밀번호는 SETUP.md 참고.
DATABASE_URL=postgresql://whereistruck:WhereIsTrucksOwnerIsJinLee@localhost:5432/whereistruck

# Auth (Firebase Admin SDK)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# 또는 서비스 계정 JSON 경로
# GOOGLE_APPLICATION_CREDENTIALS=path/to/serviceAccountKey.json

# Backend
PORT=3000
NODE_ENV=development
