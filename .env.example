# Map API (Google Maps 또는 Kakao Map)
MAP_API_KEY=
# MAP_PROVIDER=google|kakao

# Database (PostgreSQL + PostGIS). 비밀번호는 SETUP.md 참고.
DATABASE_URL=postgresql://whereistruck:WhereIsTrucksOwnerIsJinLee@localhost:5432/whereistruck

# Auth (Firebase Admin SDK)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# 또는 서비스 계정 JSON 경로
# GOOGLE_APPLICATION_CREDENTIALS=path/to/serviceAccountKey.json

# Backend
PORT=3000
NODE_ENV=development
